rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminEmails() {
      return [
        "hello@nesthelperwa.com",
        "nesthelperwa@gmail.com"
      ];
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email in adminEmails();
    }

    match /serviceRequests/{docId} {
      allow create: if false; // public submissions should go through Next.js API route
      allow read, update, delete: if isAdmin();
    }

    match /helperApplications/{docId} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    match /partnerApplications/{docId} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    match /contactMessages/{docId} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    match /referralLinks/{docId} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    match /referralRewards/{docId} {
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
