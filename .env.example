# NEXT.JS
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BUSINESS_NAME=NestHelper LLC
NEXT_PUBLIC_CONTACT_EMAIL=hello@nesthelperwa.com
NEXT_PUBLIC_CONTACT_PHONE=(425) 000-0000

# FIREBASE CLIENT CONFIG - safe to expose when rules are configured correctly
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# STRIPE SERVER CONFIG
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs - create these in Stripe as tax-exclusive prices with automatic tax enabled in Checkout.
STRIPE_PRICE_PARENT_RESET_STANDARD=
STRIPE_PRICE_PARENT_RESET_FOUNDING=
STRIPE_PRICE_FAMILY_RESET_STANDARD=
STRIPE_PRICE_FAMILY_RESET_FOUNDING=
STRIPE_PRICE_HELPER_BLOCK_STANDARD=
STRIPE_PRICE_HELPER_BLOCK_FOUNDING=
STRIPE_PRICE_ERRAND_STANDARD=
STRIPE_PRICE_ERRAND_FOUNDING=
STRIPE_PRICE_LAUNDRY_DEPOSIT_STANDARD=
STRIPE_PRICE_LAUNDRY_DEPOSIT_FOUNDING=

# Keep false for request-first launch. Use the API route only after you are ready to automate approved checkouts.
ENABLE_PUBLIC_CHECKOUT=false
